  "productName": "Profession Archives",
  "version": "0.1.0",
  "identifier": "com.professionarchives.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
